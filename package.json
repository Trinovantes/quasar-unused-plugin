{
    "name": "quasar-unused-plugin",
    "version": "0.3.9",
    "description": "Webpack 5 plugin for tree shaking unused Quasar components from generated bundles",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "README.md",
        "dist/*",
        "src/*"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/Trinovantes/quasar-unused-plugin"
    },
    "author": {
        "name": "Stephen",
        "email": "hello@stephenli.ca",
        "url": "https://www.stephenli.ca"
    },
    "license": "MIT",
    "private": false,
    "scripts": {
        "prepublishOnly": "pnpm clean && pnpm build",
        "clean": "rm -rf ./dist",
        "lint": "vue-tsc && eslint",
        "test": "vitest",
        "build": "vite build",
        "exDev": "  NODE_ENV=development webpack --watch --config example/webpack.config.ts",
        "exBuild": "NODE_ENV=production  webpack         --config example/webpack.config.ts",
        "exWatch": "NODE_ENV=development nodemon -r source-map-support/register dist/example/www.js --watch dist/example",
        "exStart": "NODE_ENV=production  node    -r source-map-support/register dist/example/www.js",
        "exAnalyze": "WEBPACK_ANALYZE=true NODE_ENV=production webpack --config example/webpack.config.ts"
    },
    "dependencies": {
        "@sinclair/typebox": "^0.34.48"
    },
    "peerDependencies": {
        "quasar": ">= 2.16",
        "webpack": "^5.28.0"
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.3",
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/estree": "^1.0.8",
        "@types/express": "^4.17.25",
        "@types/jsdom": "^28.0.1",
        "@types/node": "^24.10.15",
        "@types/webpack": "^5.28.5",
        "@types/webpack-bundle-analyzer": "^4.7.0",
        "@vue/server-renderer": "^3.5.30",
        "copy-webpack-plugin": "^14.0.0",
        "css-loader": "^7.1.4",
        "esbuild-loader": "^4.4.2",
        "eslint": "^10.1.0",
        "eslint-plugin-n": "^17.24.0",
        "eslint-plugin-vue": "^10.8.0",
        "express": "^4.22.1",
        "globals": "^17.4.0",
        "mini-css-extract-plugin": "^2.10.1",
        "null-loader": "^4.0.1",
        "quasar": "^2.19.1",
        "sass": "^1.98.0",
        "sass-loader": "^16.0.7",
        "source-map-support": "^0.5.21",
        "terser-webpack-plugin": "^5.4.0",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.2",
        "typescript-eslint": "^8.57.2",
        "vite": "^8.0.2",
        "vite-plugin-dts": "^4.5.4",
        "vitest": "^4.1.1",
        "vue": "^3.5.30",
        "vue-eslint-parser": "^10.4.0",
        "vue-loader": "^17.4.2",
        "vue-router": "^5.0.4",
        "vue-ssr-assets-plugin": "^0.4.8",
        "vue-tsc": "^3.2.6",
        "webpack": "^5.105.4",
        "webpack-bundle-analyzer": "^5.2.0",
        "webpack-cli": "^7.0.2",
        "webpack-merge": "^6.0.1"
    }
}
